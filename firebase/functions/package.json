{
  "name": "nitaai-firebase-functions",
  "private": true,
  "engines": { "node": "18" },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
